schema {
  query: QueryRootType
}

type QueryRootType {
  me: User
}

type User {
  id: ID!
  name: String!
  email: String!
  createdAt: Date!
  updatedAt: Date!
}

scalar Date @specifiedBy(url: "https://tools.ietf.org/html/rfc3339")

scalar Url @specifiedBy(url: "https://www.w3.org/Addressing/URL/url-spec.txt")
